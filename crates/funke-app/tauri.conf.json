{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Funke",
  "identifier": "me.klappstuhl.funke",
  "build": {
    "frontendDist": "./ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Funke",
        "width": 680,
        "height": 56,
        "center": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "publisher": "klappstuhlpy",
    "homepage": "https://github.com/klappstuhlpy/funke",
    "copyright": "Copyright (c) 2026 klappstuhlpy",
    "category": "Utility",
    "shortDescription": "A fast, extensible Spotlight-style launcher for Windows.",
    "longDescription": "Summon a search bar with a global hotkey, then launch apps, find files, switch windows, run actions, and search your Bitwarden/Vaultwarden vault with autotype - all from the keyboard.",
    "licenseFile": "../../LICENSE",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico",
        "headerImage": "installer/header.bmp",
        "sidebarImage": "installer/sidebar.bmp",
        "installerHooks": "installer/hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://github.com/klappstuhlpy/funke/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxOTQwQjg3NkQ0NTAwQUMKUldTc0FFVnRod3VVTVdmczVUYm4rVmdBWk9ZRVRJZHB4S21wcXFjblBRK3FUakFtRlBIMEpOV3MK"
    }
  }
}
